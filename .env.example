# Copy to .env and fill in. .env is gitignored.

# deployer key for forge script (do not commit a real key)
PRIVATE_KEY=

# WanePolicy to wire the factory to. Defaults to the live Base mainnet policy
# if unset.
POLICY=0x26deE4503C7f67356837ED41cE285026EF256667

# RPC endpoints used by foundry.toml [rpc_endpoints]
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=
MAINNET_RPC_URL=

# BaseScan key for contract verification
BASESCAN_API_KEY=
